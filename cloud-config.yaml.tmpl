#cloud-config

# https://community.hetzner.com/tutorials/basic-cloud-config

hostname: ${hostname}

users:
  - name: sysadmin
    groups: users, admin
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
      - ${pub_key}

packages:
  - ufw
  - unattended-upgrades
  - docker.io
  - docker-compose-v2
  - git
  - ncdu
  - htop
  - iotop
  - curl
  - wget
  - jq
  - vim
  - tmux
  - ripgrep
  - gh
  - fzf

package_update: true
package_upgrade: true

# Set timezone
timezone: Europe/Berlin

# Configure NTP
ntp:
  enabled: true

write_files:

  # Add Docker daemon config with logging limits
  - path: /etc/docker/daemon.json
    content: |
      {
        "iptables": true,
        "log-driver": "json-file",
        "log-opts": {
          "max-size": "10m",
          "max-file": "3"
        },
        "live-restore": true
      }

  # Add automatic Docker cleanup cron
  - path: /etc/cron.weekly/docker-cleanup
    permissions: '0755'
    content: |
      #!/bin/bash
      docker system prune -af --filter "until=168h"

  # MOTD with system info
  - path: /etc/update-motd.d/99-custom
    permissions: '0755'
    content: |
      #!/bin/bash
      echo ""
      echo "=== System Info ==="
      echo "Hostname: $$(hostname)"
      echo "Uptime: $$(uptime -p)"
      echo "Memory: $$(free -h | awk '/^Mem:/ {print $$3 "/" $$2}')"
      echo "Disk: $$(df -h / | awk 'NR==2 {print $$3 "/" $$2 " (" $$5 " used)"}')"
      echo "Docker: $$(docker ps -q 2>/dev/null | wc -l) containers running"
      echo ""

# Create swap file (2GB)
swap:
  filename: /swapfile
  size: 2G
  maxsize: 2G

runcmd:
  # Setup user home directory with skeleton files
  - cp -r /etc/skel/. /home/sysadmin/
  - chown -R sysadmin:sysadmin /home/sysadmin
  - chmod 755 /home/sysadmin

  # Setup Ghostty terminal support
  - |
    # Modify default .bashrc to support ghostty colors earlier in the file
    sed -i '/xterm-color|\*-256color) color_prompt=yes;;/a\    xterm-ghostty) color_prompt=yes; export COLORTERM=truecolor;;' /home/sysadmin/.bashrc
  
  # Enhance bash history configuration
  - |
    # Increase history size limits
    sed -i 's/^HISTSIZE=1000/HISTSIZE=50000/' /home/sysadmin/.bashrc
    sed -i 's/^HISTFILESIZE=2000/HISTFILESIZE=100000/' /home/sysadmin/.bashrc
    
    # Add timestamp to history entries
    echo 'HISTTIMEFORMAT="%F %T  "' >> /home/sysadmin/.bashrc
    
    # Avoid duplicates and ignore commands starting with space
    sed -i 's/^HISTCONTROL=ignoreboth/HISTCONTROL=ignoreboth:erasedups/' /home/sysadmin/.bashrc
    
    # Append to history immediately (not just on shell exit)
    echo 'PROMPT_COMMAND="history -a; history -n"' >> /home/sysadmin/.bashrc
    
    # Don't save certain commands to history
    echo 'HISTIGNORE="ls:ll:cd:pwd:exit:clear:history"' >> /home/sysadmin/.bashrc
    
    # Enable fzf for better history search (Ctrl+R)
    echo 'source /usr/share/doc/fzf/examples/key-bindings.bash' >> /home/sysadmin/.bashrc
    
    # fzf configuration for better UX
    echo 'export FZF_DEFAULT_OPTS="--height 40% --reverse --border"' >> /home/sysadmin/.bashrc
    echo 'export FZF_CTRL_R_OPTS="--preview '\''echo {}\'\'' --preview-window down:3:hidden:wrap --bind '\''?:toggle-preview'\''"' >> /home/sysadmin/.bashrc
    
    # Use fd instead of find for faster file discovery with fzf
    echo 'export FZF_DEFAULT_COMMAND='\''fd --type f --hidden --follow --exclude .git'\''' >> /home/sysadmin/.bashrc
    echo 'export FZF_ALT_C_COMMAND='\''fd --type d --hidden --follow --exclude .git'\''' >> /home/sysadmin/.bashrc
    echo 'export FZF_CTRL_T_COMMAND='\''fd --type f --hidden --follow --exclude .git'\''' >> /home/sysadmin/.bashrc

  # Disable sudo hint on login (but keep MOTD)
  - touch /home/sysadmin/.sudo_as_admin_successful
  - chown sysadmin:sysadmin /home/sysadmin/.sudo_as_admin_successful

  # Firewall Setup
  - ufw allow 443/tcp
  - ufw allow 41641/udp
  - ufw allow in on tailscale0
  - ufw --force enable

  # Docker setup
  - systemctl restart docker
  - usermod -aG docker sysadmin

  # Enable Auto-updates
  - systemctl enable --now unattended-upgrades

  # Tailscale VPN Setup
  - curl -fsSL https://tailscale.com/install.sh | sh
  - tailscale up --authkey=${tailscale_key} --ssh --accept-routes

  # Install latest fd (remove conflicting fdclone, download latest from GitHub)
  - apt remove -y fdclone fd-find
  - |
    cd /tmp && \
    LATEST_VERSION=$$(curl -s https://api.github.com/repos/sharkdp/fd/releases/latest | jq -r .tag_name) && \
    curl -LO "https://github.com/sharkdp/fd/releases/download/$${LATEST_VERSION}/fd_$${LATEST_VERSION#v}_amd64.deb" && \
    dpkg -i fd_*_amd64.deb && \
    rm fd_*_amd64.deb

  # Configure gh CLI and Docker GHCR authentication (if token provided)
  - |
    if [ -n "${github_token}" ]; then
      sudo -u sysadmin gh auth login --with-token <<< "${github_token}"
      sudo -u sysadmin sh -c "echo '${github_token}' | docker login ghcr.io -u nobody --password-stdin"
    fi

  # Reboot
  - reboot
