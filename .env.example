# Example .env file
# Copy this to .env and fill in your values

# Hetzner Cloud API token
export HCLOUD_TOKEN=$(op read --account my.1password.com "op://Private/your-hetzner-token/credential")

# SSH key name in Hetzner account
# See: https://console.hetzner.com/projects/YOUR_PROJECT_ID/security/sshkeys
export SSH_KEY_NAME=Hetzner Automation Key

# Public SSH key to install on servers
export PUB_KEY=$(op read --account my.1password.com "op://Private/Hetzner Automation Key/public key")

# Tailscale auth key for Hetzner servers
# See: https://login.tailscale.com/admin/settings/keys
export TAILSCALE_AUTH_KEY=$(op read --account my.1password.com "op://Private/Tailscale Hetzner Auth Key/credential")
