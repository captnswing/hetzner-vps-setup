# Copy this file to `.env` and fill in your values, then run:
#   make doctor          # verify everything is set up
#   uv run setup-vps.py  # provision
#
# `.env` is gitignored — your real values never get committed. The script loads it
# automatically (python-dotenv); no need to `source` it.
#
# (Maintainer alternative: 1Password injection via `op-run` + `.op.env`. That setup
#  is personal and optional — see the "Advanced" section of the README. You don't
#  need it to use this project.)

# Hetzner Cloud API token, Read & Write.
# Create at https://console.hetzner.cloud/ -> Security -> API Tokens
HCLOUD_TOKEN=your-hetzner-api-token

# Name of your SSH key EXACTLY as it appears in the Hetzner console.
# https://console.hetzner.cloud/ -> Security -> SSH Keys
SSH_KEY_NAME=Hetzner Automation Key

# The PUBLIC SSH key text installed on the server — the contents of e.g.
# ~/.ssh/Hetzner_Automation_Key.pub (starts with "ssh-ed25519 AAAA...").
PUB_KEY=ssh-ed25519 AAAAExampleReplaceWithYourPublicKey you@example.com

# Tailscale auth key: reusable, tagged `tag:vps`, NOT ephemeral.
# https://login.tailscale.com/admin/settings/keys  (see README for the one-time ACL tag step)
TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxxxxxxxxxxxxxx

# Optional — enables gh CLI + Docker GHCR auto-login on the server.
# Leave blank to skip.
GITHUB_TOKEN=
